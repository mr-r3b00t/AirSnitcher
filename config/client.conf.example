# AirSnitch – WPA supplicant configuration
# ──────────────────────────────────────────────────────────────────────────────
# This file configures two connections used by AirSnitch:
#   1. "victim"   – simulates the target client
#   2. "attacker" – the adversary connection
#
# Copy this file to client.conf and update the credentials for your network.
# ──────────────────────────────────────────────────────────────────────────────

# Do not change this — AirSnitch requires wpaspy_ctrl
ctrl_interface=wpaspy_ctrl

# ── Victim connection ────────────────────────────────────────────────────────
network={
    ssid="YourNetworkSSID"
    psk="YourNetworkPassword"
    id_str="victim"
    key_mgmt=WPA-PSK
    # For WPA3-SAE, use:
    #   key_mgmt=SAE
    #   ieee80211w=2
}

# ── Attacker connection ─────────────────────────────────────────────────────
network={
    ssid="YourNetworkSSID"
    psk="YourNetworkPassword"
    id_str="attacker"
    key_mgmt=WPA-PSK
}
